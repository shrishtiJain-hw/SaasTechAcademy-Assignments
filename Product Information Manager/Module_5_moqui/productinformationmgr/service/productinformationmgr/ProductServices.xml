<?xml version="1.0" encoding="UTF-8"?>
<services xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/service-definition-3.xsd">

    <!-- ========================================================= -->
    <!-- PimProduct Services                                       -->
    <!-- ========================================================= -->

    <service verb="create" noun="PimProduct">
        <in-parameters>
            <parameter name="productId" required="true"/>
            <parameter name="productName" required="true"/>
            <parameter name="productTypeId" required="true"/>
            <parameter name="isVirtual" default="'N'"/>
            <parameter name="isVariant" default="'N'"/>
        </in-parameters>
        <actions>
            <entity-make-value entity-name="productinformationmgr.PimProduct" value-field="newProduct" map="context"/>
            <entity-create value-field="newProduct"/>
        </actions>
    </service>

    <service verb="update" noun="PimProduct">
        <in-parameters>
            <parameter name="productId" required="true"/>
            <parameter name="productName"/>
            <parameter name="productTypeId"/>
            <parameter name="isVirtual"/>
            <parameter name="isVariant"/>
        </in-parameters>
        <actions>
            <entity-find-one entity-name="productinformationmgr.PimProduct" value-field="product"/>
            <if condition="product">
                <entity-set-values value-field="product" map="context"/>
                <entity-update value-field="product"/>
            </if>
        </actions>
    </service>

    <!-- ========================================================= -->
    <!-- PimProductContent Services                                -->
    <!-- ========================================================= -->

    <service verb="create" noun="PimProductContent">
        <in-parameters>
            <parameter name="productContentId"/>
            <parameter name="productId" required="true"/>
            <parameter name="productContentTypeId" required="true"/>
            <parameter name="contentLocation" required="true"/>
        </in-parameters>
        <out-parameters>
            <parameter name="productContentId" required="true"/>
        </out-parameters>
        <actions>
            <if condition="!productContentId">
                <set field="productContentId" from="ec.entity.sequencedIdPrimary('productinformationmgr.PimProductContent', null, null)"/>
            </if>
            <entity-make-value entity-name="productinformationmgr.PimProductContent" value-field="newProductContent" map="context"/>
            <entity-create value-field="newProductContent"/>
        </actions>
    </service>

