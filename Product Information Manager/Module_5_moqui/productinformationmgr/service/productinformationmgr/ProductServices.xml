    <!-- PimProductPrice Services                                  -->
    <!-- ========================================================= -->

    <service verb="create" noun="PimProductPrice">
        <in-parameters>
            <parameter name="productPriceId"/>
            <parameter name="productId" required="true"/>
            <parameter name="productPriceTypeId" required="true"/>
            <parameter name="price" type="BigDecimal" required="true"/>
        </in-parameters>
        <out-parameters>
            <parameter name="productPriceId" required="true"/>
        </out-parameters>
        <actions>
            <if condition="!productPriceId">
                <set field="productPriceId" from="ec.entity.sequencedIdPrimary('productinformationmgr.PimProductPrice', null, null)"/>
            </if>
            <entity-make-value entity-name="productinformationmgr.PimProductPrice" value-field="newProductPrice" map="context"/>
            <entity-create value-field="newProductPrice"/>
        </actions>
    </service>

