<?xml version="1.0" encoding="UTF-8"?>
<screen xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/xml-screen-3.xsd"
    default-menu-title="Parties List" default-menu-index="1">

    <transition name="createPerson">
        <service-call name="relationshipmgr.PartyServices.create#RmPerson"/>
        <default-response url="."/>
    </transition>

    <transition name="createOrganization">
        <service-call name="relationshipmgr.PartyServices.create#RmOrganization"/>
        <default-response url="."/>
    </transition>

    <actions>
        <entity-find entity-name="relationshipmgr.RmPartyDetailView" list="partyList">
            <order-by field-name="partyId"/>
        </entity-find>
    </actions>

    <widgets>
        <container-row>
            <row-col lg="6" md="6" sm="12">
                <container-box>
                    <box-header title="Create Person"/>
                    <box-body>
                        <form-single name="CreatePersonForm" transition="createPerson">
                            <field name="partyId"><default-field title="Party ID (Optional)"><text-line size="20"/></default-field></field>
                            <field name="firstName"><default-field title="First Name"><text-line size="30"/></default-field></field>
                            <field name="lastName"><default-field title="Last Name"><text-line size="30"/></default-field></field>
                            <field name="birthDate"><default-field title="Birth Date"><date-time type="date"/></default-field></field>
                            <field name="submitButton"><default-field title="Create Person"><submit/></default-field></field>
                        </form-single>
                    </box-body>
                </container-box>
            </row-col>

            <row-col lg="6" md="6" sm="12">
                <container-box>
                    <box-header title="Create Organization"/>
                    <box-body>
                        <form-single name="CreateOrgForm" transition="createOrganization">
                            <field name="partyId"><default-field title="Party ID (Optional)"><text-line size="20"/></default-field></field>
                            <field name="organizationName"><default-field title="Organization Name"><text-line size="40"/></default-field></field>
                            <field name="submitButton"><default-field title="Create Organization"><submit/></default-field></field>
                        </form-single>
                    </box-body>
                </container-box>
            </row-col>
        </container-row>

        <container-box>
            <box-header title="Parties List"/>
            <box-body>
                <form-list name="ListParties" list="partyList" skip-form="true">
                    <field name="partyId">
                        <header-field show-order-by="true" title="Party ID"/>
                        <default-field>
                            <link url="../PartyDetail" text="${partyId}">
                                <parameter name="partyId"/>
                            </link>
                        </default-field>
                    </field>
                    <field name="partyTypeId">
                        <header-field show-order-by="true" title="Type"/>
                        <default-field><label text="${partyTypeId}"/></default-field>
                    </field>
                    <field name="name">
                        <header-field title="Name"/>
                        <default-field>
                            <label text="${firstName ?: ''} ${lastName ?: ''} ${organizationName ?: ''}"/>
                        </default-field>
                    </field>
                </form-list>
            </box-body>
        </container-box>
    </widgets>
</screen>
