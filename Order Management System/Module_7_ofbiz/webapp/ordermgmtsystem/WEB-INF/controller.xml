<site-conf xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="http://ofbiz.apache.org/Site-Conf" xsi:schemaLocation="http://ofbiz.apache.org/Site-Conf http://ofbiz.apache.org/dtds/site-conf.xsd">
    <include location="component://common/webcommon/WEB-INF/common-controller.xml"/>

    <description>Ordermgmtsystem Component Site Configuration File</description>

    <!-- Request Mappings -->
    <request-map uri="main">
        <security https="true" auth="true"/>
        <response name="success" type="request-redirect" value="findOrder"/>
    </request-map>

    <!-- Find Order Screen Request -->
    <request-map uri="findOrder">
        <security https="true" auth="true"/>
        <response name="success" type="view" value="findOrder"/>
    </request-map>

    <!-- Find Order Ship Groups Request -->
    <request-map uri="findOrderShipGroups">
        <security https="true" auth="true"/>
        <response name="success" type="view" value="findOrderShipGroups"/>
    </request-map>

    <!-- Create Order Event Mapping -->
    <request-map uri="createOrder">
        <security https="true" auth="true"/>
        <event type="service" invoke="createOrder"/>
        <response name="success" type="request-redirect" value="findOrder"/>
        <response name="error" type="view" value="findOrder"/>
    </request-map>

    <!-- Update Order Shipping Address Event Mapping -->
    <request-map uri="updateOrderShippingAddress">
        <security https="true" auth="true"/>
        <event type="service" invoke="updateOrderShippingAddress"/>
        <response name="success" type="request-redirect" value="findOrder"/>
        <response name="error" type="view" value="findOrder"/>
    </request-map>

    <!-- Create Ship Group Event Mapping -->
    <request-map uri="createOrderItemShipGroup">
        <security https="true" auth="true"/>
        <event type="service" invoke="createOrderItemShipGroup"/>
        <response name="success" type="request-redirect" value="findOrderShipGroups"/>
        <response name="error" type="view" value="findOrderShipGroups"/>
    </request-map>

    <!-- View Mappings -->
    <view-map name="findOrder" type="screen" page="component://ordermgmtsystem/widget/OrdermgmtsystemScreens.xml#FindOrder"/>
    <view-map name="findOrderShipGroups" type="screen" page="component://ordermgmtsystem/widget/OrdermgmtsystemScreens.xml#FindOrderShipGroups"/>
</site-conf>