    <!-- View Mappings -->
    <view-map name="FindProduct" type="screen" page="component://productinformationmgr/webapp/productinformationmgr/product/ProductScreens.xml#FindProduct"/>
    <view-map name="EditProduct" type="screen" page="component://productinformationmgr/webapp/productinformationmgr/product/ProductScreens.xml#EditProduct"/>
    <view-map name="FindFacility" type="screen" page="component://productinformationmgr/webapp/productinformationmgr/product/ProductScreens.xml#FindFacility"/>
    <view-map name="EditFacility" type="screen" page="component://productinformationmgr/webapp/productinformationmgr/product/ProductScreens.xml#EditFacility"/>
</site-conf>