        <response name="success" type="request-redirect" value="EditProduct">
            <redirect-parameter name="productId"/>
        </response>
        <response name="error" type="view" value="EditProduct"/>
    </request-map>

    <!-- Categories & Features Mappings -->
    <request-map uri="createPimProductCategory">
        <security https="true" auth="true"/>
        <event type="service" invoke="createPimProductCategory"/>
        <response name="success" type="request-redirect" value="FindProduct"/>
        <response name="error" type="view" value="FindProduct"/>
