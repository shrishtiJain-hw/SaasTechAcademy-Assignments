<forms xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="http://ofbiz.apache.org/Widget-Form" xsi:schemaLocation="http://ofbiz.apache.org/Widget-Form http://ofbiz.apache.org/dtds/widget-form.xsd">

    <form name="ListParties" type="list" list-name="listIt" paginate-target="FindParty"
        odd-row-style="alternate-row" header-row-style="header-row-2" default-table-style="basic-table hover-bar">
        <actions>
            <entity-condition entity-name="RmParty">
                <order-by field-name="partyId"/>
            </entity-condition>
        </actions>
        <field name="partyId" title="Party ID" widget-style="buttontext">
            <hyperlink description="${partyId}" target="EditParty">
                <parameter param-name="partyId"/>
            </hyperlink>
        </field>
        <field name="partyTypeId" title="Type"><display/></field>
    </form>

    <form name="EditPerson" type="single" target="updateRmPerson" default-map-name="person">
        <alt-target use-when="person==null" target="createRmPerson"/>
        <auto-fields-service service-name="createRmPerson"/>
        <field name="partyId" use-when="person!=null"><display/></field>
        <field name="partyId" use-when="person==null"><lookup target-form-name="LookupRmParty" action="partyId"/></field>
        <field name="submitButton" title="${uiLabelMap.CommonSave}" widget-style="smallSubmit"><submit button-type="button"/></field>
    </form>

    <form name="EditOrganization" type="single" target="updateRmOrganization" default-map-name="organization">
        <alt-target use-when="organization==null" target="createRmOrganization"/>
        <auto-fields-service service-name="createRmOrganization"/>
        <field name="partyId" use-when="organization!=null"><display/></field>
        <field name="partyId" use-when="organization==null"><lookup target-form-name="LookupRmParty" action="partyId"/></field>
        <field name="submitButton" title="${uiLabelMap.CommonSave}" widget-style="smallSubmit"><submit button-type="button"/></field>
    </form>

    <form name="AddPartyRole" type="single" target="createRmPartyRole">
        <field name="partyId"><hidden/></field>
        <field name="roleTypeId" title="Role Type"><text/></field>
        <field name="submitButton" title="Add Role" widget-style="smallSubmit"><submit button-type="button"/></field>
    </form>

    <form name="ListPartyRoles" type="list" list-name="partyRoles"
        odd-row-style="alternate-row" default-table-style="basic-table hover-bar">
        <field name="roleTypeId" title="Role Type"><display/></field>
    </form>

    <form name="AddContactMech" type="single" target="createRmContactMech">
        <field name="partyId"><hidden/></field>
        <field name="contactMechTypeId" title="Type">
            <drop-down>
                <option key="POSTAL_ADDRESS" description="Postal Address"/>
                <option key="TELECOM_NUMBER" description="Telecom Number"/>
                <option key="EMAIL_ADDRESS" description="Email Address"/>
            </drop-down>
        </field>
        <field name="infoString" title="Info"><text/></field>
        <field name="submitButton" title="Add Contact" widget-style="smallSubmit"><submit button-type="button"/></field>
    </form></forms>