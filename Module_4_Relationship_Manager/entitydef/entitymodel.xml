<?xml version="1.0" encoding="UTF-8"?>

<entitymodel xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:noNamespaceSchemaLocation="https://ofbiz.apache.org/dtds/entitymodel.xsd">

    <entity entity-name="RmParty"
            package-name="org.relationshipmgr"
            title="Party">

        <field name="partyId" type="id"/>
        <field name="partyTypeId" type="id"/>

        <prim-key field="partyId"/>
    </entity>


    <entity entity-name="RmPerson"
            package-name="org.relationshipmgr"
            title="Person">

        <field name="partyId" type="id"/>
        <field name="firstName" type="name"/>
        <field name="lastName" type="name"/>
        <field name="birthDate" type="date"/>

        <prim-key field="partyId"/>

        <relation type="one"
                  rel-entity-name="RmParty"
                  fk-name="RM_PERSON_PARTY">

            <key-map field-name="partyId"/>
        </relation>
    </entity>


    <entity entity-name="RmOrganization"
            package-name="org.relationshipmgr"
            title="Organization">

        <field name="partyId" type="id"/>
        <field name="organizationName" type="name"/>

        <prim-key field="partyId"/>

        <relation type="one"
                  rel-entity-name="RmParty"
                  fk-name="RM_ORG_PARTY">

            <key-map field-name="partyId"/>
        </relation>
    </entity>


    <entity entity-name="RmPartyRole"
            package-name="org.relationshipmgr"
            title="Party Role">

        <field name="partyId" type="id"/>
        <field name="roleTypeId" type="id-long"/>

        <prim-key field="partyId"/>
        <prim-key field="roleTypeId"/>

        <relation type="one"
                  rel-entity-name="RmParty"
                  fk-name="RM_ROLE_PARTY">

            <key-map field-name="partyId"/>
        </relation>
    </entity>


    <entity entity-name="RmContactMech"
            package-name="org.relationshipmgr"
            title="Contact Mechanism">
        <field name="contactMechId" type="id"/>
        <field name="contactMechTypeId" type="id"/>
        <field name="infoString" type="long-varchar"/>
        <prim-key field="contactMechId"/>
    </entity>

    <entity entity-name="RmTelecomNumber"
            package-name="org.relationshipmgr"
            title="Telecommunications Number">
        <field name="contactMechId" type="id"/>
        <field name="countryCode" type="very-short"/>
        <field name="areaCode" type="very-short"/>
        <field name="contactNumber" type="short-varchar"/>
        <prim-key field="contactMechId"/>
        <relation type="one" fk-name="RM_TEL_NUM_CMECH" rel-entity-name="RmContactMech">
            <key-map field-name="contactMechId"/>
        </relation>
    </entity>

    <entity entity-name="RmPostalAddress"
            package-name="org.relationshipmgr"
            title="Postal Address">
        <field name="contactMechId" type="id"/>
        <field name="toName" type="name"/>
        <field name="attnName" type="name"/>
        <field name="address1" type="long-varchar"/>
        <field name="address2" type="long-varchar"/>
        <field name="city" type="name"/>
        <field name="postalCode" type="short-varchar"/>
        <prim-key field="contactMechId"/>
        <relation type="one" fk-name="RM_POST_ADDR_CMECH" rel-entity-name="RmContactMech">
            <key-map field-name="contactMechId"/>
        </relation>
    </entity>

    <entity entity-name="RmContactMechPurpose"
            package-name="org.relationshipmgr"
            title="Contact Mechanism Purpose">
        <field name="contactMechPurposeId" type="id-long"/>
        <field name="description" type="description"/>
        <prim-key field="contactMechPurposeId"/>
    </entity>

    <entity entity-name="RmPartyContactMech"
            package-name="org.relationshipmgr"
            title="Party Contact Mechanism">
        <field name="partyId" type="id"/>
        <field name="contactMechId" type="id"/>
        <field name="contactMechPurposeId" type="id-long"/>
        <field name="fromDate" type="date-time"/>
        <field name="thruDate" type="date-time"/>
        <prim-key field="partyId"/>
        <prim-key field="contactMechId"/>
        <prim-key field="contactMechPurposeId"/>
        <prim-key field="fromDate"/>
        <relation type="one" fk-name="RM_PTY_CMECH_PTY" rel-entity-name="RmParty">
            <key-map field-name="partyId"/>
        </relation>
        <relation type="one" fk-name="RM_PTY_CMECH_CMECH" rel-entity-name="RmContactMech">
            <key-map field-name="contactMechId"/>
        </relation>
        <relation type="one" fk-name="RM_PTY_CMECH_PURP" rel-entity-name="RmContactMechPurpose">
            <key-map field-name="contactMechPurposeId"/>
        </relation>
    </entity>

</entitymodel>